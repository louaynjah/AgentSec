      "parameters": {
        "jsCode": "const { exec } = require('child_process');\nconst util = require('util');\nconst execPromise = util.promisify(exec);\nconst fs = require('fs');\n\nconst network = $('Extraire Ports Ouverts').first().json.network;\nconst timestamp = $('Extraire Ports Ouverts').first().json.timestamp;\nconst tempDir = '/tmp/vulnscan';\nconst outputFile = `${tempDir}/nikto_${timestamp}.txt`;\n\nconsole.log('🔍 Starting Nikto scan on:', network);\n\nif (!fs.existsSync(tempDir)) {\n    fs.mkdirSync(tempDir, { recursive: true });\n}\n\nlet niktoResults = [];\n\ntry {\n    // Déterminer le protocole\n    let protocol = 'http';\n    if ($('Extraire Ports Ouverts').first().json.hasHTTPS) {\n        protocol = 'https';\n    }\n    \n    // Commande Nikto simplifiée\n    const cmd = `nikto -h ${protocol}://${network} -ssl -port 443 -nointeractive -timeout 5 -maxtime 120 -Format csv -o ${outputFile}`;\n    console.log('CMD:', cmd);\n    \n    try {\n        await execPromise(cmd, { timeout: 150000, shell: '/bin/bash' });\n    } catch(e) {\n        console.log('Nikto scan completed (may have findings)');\n    }\n    \n    // Lire les résultats\n    if (fs.existsSync(outputFile)) {\n        const content = fs.readFileSync(outputFile, 'utf-8');\n        console.log('File size:', content.length);\n        \n        const lines = content.split('\\n').filter(l => l.trim());\n        \n        for (const line of lines) {\n            // Format CSV: \"host\",\"port\",\"banner\",\"method\",\"item\",\"msg\"\n            if (line.includes('+') || line.includes('OSVDB')) {\n                const cleanLine = line.replace(/^[+\"]+|[\"]+$/g, '').trim();\n                if (cleanLine.length > 10 && !cleanLine.startsWith('Target')) {\n                    niktoResults.push({\n                        tool: 'nikto',\n                        type: 'web_vulnerability',\n                        id: cleanLine.match(/OSVDB-\\d+|CVE-\\d+-\\d+/)?.[0] || 'FINDING',\n                        method: 'GET',\n                        url: `${protocol}://${network}`,\n                        msg: cleanLine.substring(0, 200),\n                        remediation: 'Review and patch accordingly'\n                    });\n                }\n            }\n        }\n    }\n    \n    console.log(`✅ Nikto found ${niktoResults.length} issues`);\n    \n    if (niktoResults.length === 0) {\n        niktoResults.push({\n            tool: 'nikto',\n            type: 'info',\n            id: 'NO_ISSUES',\n            msg: 'No vulnerabilities detected by Nikto',\n            url: `${protocol}://${network}`\n        });\n    }\n    \n} catch (error) {\n    console.error('❌ Nikto error:', error.message);\n    niktoResults.push({\n        tool: 'nikto',\n        type: 'error',\n        id: 'SCAN_ERROR',\n        msg: `Nikto scan error: ${error.message}`,\n        url: network\n    });\n}\n\nreturn [{ json: { niktoResults } }];"
