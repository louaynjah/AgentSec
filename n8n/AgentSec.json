    {
      "parameters": {
        "jsCode": "const { execSync } = require('child_process');\nconst fs = require('fs');\nconst path = require('path');\n\nconst portsData = $('Extraire Ports Ouverts').first().json;\nconst network = portsData.network;\nconst timestamp = portsData.timestamp;\nconst httpPort = portsData.httpPort || 80;\nconst tempDir = '/tmp/vulnscan';\nconst wordlist = '/tmp/vulnscan/wordlist.txt';\nconst outFile = path.join(tempDir, `gobuster_${timestamp}.txt`);\n\n// Vérifier si gobuster est installé\ntry {\n    execSync('which gobuster', { encoding: 'utf-8' });\n} catch (e) {\n    return [{ json: { gobusterResults: [], error: 'Gobuster not found. Installez avec: sudo apt-get install gobuster' } }];\n}\n\n// Créer la wordlist si elle n'existe pas\nif (!fs.existsSync(wordlist)) {\n    console.log('Wordlist not found, downloading...');\n    try {\n        execSync(\n            `wget -O ${wordlist} https://raw.githubusercontent.com/danielmiessler/SecLists/master/Discovery/Web-Content/common.txt`,\n            { encoding: 'utf-8', timeout: 30000 }\n        );\n    } catch(e) {\n        return [{ json: { gobusterResults: [], error: 'Failed to download wordlist' } }];\n    }\n}\n\nconst target = `http://${network}:${httpPort}`;\nconsole.log('Gobuster target:', target);\n\ntry {\n    const cmd = `gobuster dir -u \"${target}\" -w \"${wordlist}\" -o \"${outFile}\" -t 10 -q --no-error --timeout 5s`;\n    console.log('CMD:', cmd);\n    \n    try {\n        execSync(cmd, { encoding: 'utf-8', timeout: 50000, shell: '/bin/bash' });\n    } catch(e) {\n        console.log('Gobuster stopped:', e.message.substring(0, 80));\n    }\n\n    let gobusterResults = [];\n    if (fs.existsSync(outFile)) {\n        const content = fs.readFileSync(outFile, 'utf-8');\n        console.log('Gobuster output length:', content.length);\n        \n        for (const line of content.split('\\n').filter(l => l.trim())) {\n            const m = line.match(/^(\\S+)\\s+\\(Status:\\s*(\\d+)\\)(?:\\s+\\[Size:\\s*(\\d+)\\])?/);\n            if (m) {\n                gobusterResults.push({ \n                    tool: 'gobuster', \n                    type: 'directory', \n                    path: m[1], \n                    status: m[2], \n                    size: m[3] || '' \n                });\n            }\n        }\n    }\n\n    console.log(`Gobuster found ${gobusterResults.length} paths`);\n    return [{ json: { gobusterResults } }];\n\n} catch (error) {\n    console.error('Gobuster error:', error.message);\n    return [{ json: { gobusterResults: [], error: error.message } }];\n}"
      },
      "id": "7ddacdf5-c918-4ac0-9de5-a516d459827c",
      "name": "Gobuster",
