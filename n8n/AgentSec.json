        "jsCode": "// Nœud \"Check Status\"\nconst params = $input.first().json;\nconst scanId = params.scanId || params.query?.scanId;\n\nconst fs = require('fs');\nconst tempDir = '/tmp/vulnscan';\nconst resultFile = `${tempDir}/results/${scanId}.json`;\nconst requestFile = `${tempDir}/request_${scanId}.json`;\n\nif (fs.existsSync(resultFile)) {\n    const results = JSON.parse(fs.readFileSync(resultFile, 'utf-8'));\n    return [{\n        json: {\n            status: 'completed',\n            scanId: scanId,\n            results: results\n        }\n    }];\n} else if (fs.existsSync(requestFile)) {\n    return [{\n        json: {\n            status: 'running',\n            scanId: scanId,\n            message: 'Scan in progress'\n        }\n    }];\n} else {\n    return [{\n        json: {\n            status: 'not_found',\n            scanId: scanId,\n            message: 'Scan ID not found'\n        }\n    }];\n}"
