{
  "name": "AgentSec",
  "nodes": [
    {
      "parameters": {
        "jsCode": "// Récupérer les données du webhook\nconst items = $input.all();\nconst item = items[0]?.json || {};\n\n// Les données arrivent directement dans le body de la requête\n// Pour un POST avec JSON, elles sont dans item.body\nconst requestBody = item.body || item;\n\n// Déterminer la source (API ou formulaire)\nconst isApi = requestBody.target !== undefined || requestBody.Cible_réseau !== undefined;\n\n// Récupérer les paramètres (support des deux formats)\nconst network = isApi\n  ? (requestBody.target || requestBody.Cible_réseau || requestBody.network)\n  : (requestBody['Cible réseau (IP ou domaine)'] || 'scanme.nmap.org');\n\nconst emailTo = isApi\n  ? (requestBody.email || requestBody.Email || requestBody.emailTo)\n  : (requestBody['Email destinataire du rapport'] || process.env.DEFAULT_REPORT_EMAIL);\n\nconst portRange = isApi\n  ? (requestBody.ports || requestBody.portRange || '1-1000')\n  : (requestBody['Plage de ports à scanner'] || '1-1000');\n\nconst timestamp = new Date().toISOString().replace(/[:.]/g, '-').substring(0, 19);\n\nconsole.log('Scan request received:');\nconsole.log('  Network:', network);\nconsole.log('  Email:', emailTo);\nconsole.log('  Ports:', portRange);\n\n// Générer un ID de scan unique\nconst scanId = `scan_${timestamp}`;\n\n// Créer le dossier des résultats\nconst fs = require('fs');\nconst tempDir = '/tmp/vulnscan';\nif (!fs.existsSync(tempDir)) {\n    fs.mkdirSync(tempDir, { recursive: true });\n}\n\n// Sauvegarder la demande de scan\nconst requestFile = `${tempDir}/request_${scanId}.json`;\nfs.writeFileSync(requestFile, JSON.stringify({\n    scanId: scanId,\n    network: network,\n    emailTo: emailTo,\n    portRange: portRange,\n    timestamp: timestamp,\n    status: 'pending',\n    createdAt: new Date().toISOString()\n}, null, 2));\n\nreturn [{\n  json: {\n    network,\n    emailTo,\n    portRange,\n    timestamp,\n    scanId,\n    tempDir: '/tmp/vulnscan',\n    source: isApi ? 'api' : 'webhook'\n  }\n}];"
      },
      "id": "d383645d-fd91-4164-957b-ccc7fa20f1c7",
      "name": "1. Préparer les Paramètres",
      "type": "n8n-nodes-base.code",
      "position": [
        336,
        64
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const nmapData = $input.first().json;\nlet raw = nmapData.stdout || '{\"host\":[]}';\n\n// Si raw est déjà un objet, on le garde, sinon on le parse\nlet parsed;\nif (typeof raw === 'string') {\n    try {\n        parsed = JSON.parse(raw);\n    } catch (e) {\n        parsed = { host: [] };\n    }\n} else {\n    parsed = raw;\n}\n\nconst hosts = parsed.host || [];\nconst network = $('1. Préparer les Paramètres').first().json.network;\nconst timestamp = $('1. Préparer les Paramètres').first().json.timestamp;\nconst tempDir = $('1. Préparer les Paramètres').first().json.tempDir;\n\nconst openPorts = [];\n\n// Parcourir les hosts\nfor (let i = 0; i < hosts.length; i++) {\n    const host = hosts[i];\n    \n    // Vérifier si host existe\n    if (!host) continue;\n    \n    // Accéder aux ports de façon sécurisée\n    const portsObj = host.ports || {};\n    const portList = portsObj.port || [];\n    \n    for (let j = 0; j < portList.length; j++) {\n        const port = portList[j];\n        if (port && port.portid) {\n            openPorts.push(parseInt(port.portid, 10));\n        }\n    }\n}\n\nconsole.log('Open ports:', JSON.stringify(openPorts));\n\n// Déterminer les ports HTTP/HTTPS\nlet hasHTTP = false;\nlet hasHTTPS = false;\nlet httpPort = 80;\nlet httpsPort = 443;\n\nconst httpPorts = [80, 8080, 8000, 8888, 3000, 5000];\nconst httpsPorts = [443, 8443, 4443, 8443];\n\nfor (let k = 0; k < openPorts.length; k++) {\n    const port = openPorts[k];\n    \n    if (httpPorts.includes(port)) {\n        hasHTTP = true;\n        httpPort = port;\n    }\n    if (httpsPorts.includes(port)) {\n        hasHTTPS = true;\n        httpsPort = port;\n    }\n}\n\n// Vérifier aussi dans les services détectés pour plus de précision\nfor (let i = 0; i < hosts.length; i++) {\n    const host = hosts[i];\n    if (!host || !host.ports || !host.ports.port) continue;\n    \n    for (let j = 0; j < host.ports.port.length; j++) {\n        const port = host.ports.port[j];\n        if (!port || !port.service) continue;\n        \n        const serviceName = (port.service.name || '').toLowerCase();\n        const portNum = parseInt(port.portid, 10);\n        \n        if (serviceName.includes('http') && !serviceName.includes('https')) {\n            hasHTTP = true;\n            httpPort = portNum;\n        }\n        if (serviceName.includes('https') || serviceName.includes('ssl')) {\n            hasHTTPS = true;\n            httpsPort = portNum;\n        }\n    }\n}\n\nconsole.log('hasHTTP:', hasHTTP, '| hasHTTPS:', hasHTTPS, '| httpPort:', httpPort, '| httpsPort:', httpsPort);\n\nreturn [{\n    json: {\n        stdout: nmapData.stdout,\n        network: network,\n        timestamp: timestamp,\n        tempDir: tempDir,\n        openPorts: openPorts,\n        hasHTTP: hasHTTP,\n        hasHTTPS: hasHTTPS,\n        httpPort: httpPort,\n        httpsPort: httpsPort\n    }\n}];"
      },
