      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const { execSync } = require('child_process');\n\nconst portsData = $('Extraire Ports Ouverts').first().json;\nconst network = portsData.network;\nconst httpsPort = portsData.httpsPort || 443;\n\nconsole.log('SSLScan target:', network + ':' + httpsPort);\n\nvar raw = '';\ntry {\n    // SSLScan installé localement (sudo apt install sslscan)\n    var cmd = `sslscan --no-colour ${network}:${httpsPort}`;\n    console.log('CMD:', cmd);\n    raw = execSync(cmd, { encoding: 'utf-8', timeout: 60000 });\n} catch(e) {\n    raw = (e.stdout || '') + (e.stderr || '');\n    console.log('SSLScan stopped:', e.message.substring(0, 80));\n}\n\nconsole.log('SSLScan output length:', raw.length);\n\nvar sslResults = [];\n\nif (raw.match(/SSLv2\\s+enabled/i))    sslResults.push({ tool:'sslscan', severity:'CRITICAL', issue:'SSLv2 enabled', recommendation:'Disable SSLv2 immediately' });\nif (raw.match(/SSLv3\\s+enabled/i))    sslResults.push({ tool:'sslscan', severity:'HIGH', issue:'SSLv3 enabled (POODLE)', recommendation:'Disable SSLv3' });\nif (raw.match(/TLSv1\\.0\\s+enabled/i)) sslResults.push({ tool:'sslscan', severity:'MEDIUM', issue:'TLS 1.0 enabled', recommendation:'Upgrade to TLS 1.2+' });\nif (raw.match(/TLSv1\\.1\\s+enabled/i)) sslResults.push({ tool:'sslscan', severity:'MEDIUM', issue:'TLS 1.1 enabled', recommendation:'Upgrade to TLS 1.2+' });\nif (raw.match(/DES-CBC3/i))           sslResults.push({ tool:'sslscan', severity:'MEDIUM', issue:'Weak cipher 3DES detected', recommendation:'Disable 3DES cipher' });\nif (raw.match(/RC4|NULL/i))           sslResults.push({ tool:'sslscan', severity:'HIGH', issue:'Weak cipher RC4/NULL', recommendation:'Disable weak ciphers' });\nif (raw.match(/expired|self.signed/i)) sslResults.push({ tool:'sslscan', severity:'HIGH', issue:'Certificate issue', recommendation:'Renew certificate' });\n\nif (sslResults.length === 0 && raw.length > 100) {\n    sslResults.push({\n        tool: 'sslscan',\n        severity: 'INFO',\n        issue: 'SSL/TLS configuration looks secure',\n        recommendation: 'No major SSL issues detected'\n    });\n}\n\nconsole.log('SSLScan found ' + sslResults.length + ' issues');\nreturn [{ json: { sslResults } }];"
      },
