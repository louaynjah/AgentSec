    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst nmapData = $('Extraire Ports Ouverts').first().json;\n\nlet niktoResults = [], sslResults = [], \n    whatwebResults = [], gobusterResults = [], wpscanResults = [],hydraResults = []; \n\nfor (const item of allItems) {\n    const d = item.json;\n    if (d.niktoResults !== undefined) niktoResults = d.niktoResults || [];\n    if (d.sslResults !== undefined) sslResults = d.sslResults || [];\n    if (d.whatwebResults !== undefined) whatwebResults = d.whatwebResults || [];\n    if (d.gobusterResults !== undefined) gobusterResults = d.gobusterResults || [];\n    if (d.wpscanResults !== undefined) wpscanResults = d.wpscanResults || [];\n  if (d.hydraResults !== undefined) hydraResults = d.hydraResults || []; \n}\n\nreturn [{ json: {\n    stdout: nmapData.stdout,\n    niktoResults,\n    sslResults,\n    whatwebResults,\n    gobusterResults,\n    wpscanResults,\n    hydraResults// Ajouté\n} }];"
      },
      "id": "003b250e-9512-40e9-b975-26c6d11148f3",
      "name": "Merge Code",
      "type": "n8n-nodes-base.code",
      "position": [
        2032,
        16
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const mergerData = $('Merge Code').first().json;\nconst targetNetwork = $('1. Préparer les Paramètres').first().json.network;\n\n// Récupérer tous les résultats (sans Nuclei)\nconst niktoItems = mergerData.niktoResults || [];\nconst sslItems = mergerData.sslResults || [];\nconst gobusterItems = mergerData.gobusterResults || [];\nconst whatwebItems = mergerData.whatwebResults || [];\nconst wpscanItems = mergerData.wpscanResults || [];\nconst hydraItems = mergerData.hydraResults || [];\n\nconsole.log('🤖 Groq AI Analysis starting...');\nconsole.log('📊 Data received:');\nconsole.log(`   Nikto: ${niktoItems.length} | SSL: ${sslItems.length} | Gobuster: ${gobusterItems.length}`);\nconsole.log(`   WhatWeb: ${whatwebItems.length} | WPScan: ${wpscanItems.length} | Hydra: ${hydraItems.length}`);\n\n// Construction du prompt amélioré (sans Nuclei)\nconst prompt = `Tu es un expert en cybersécurité offensive et défensive (OSCP, CEH, CISSP).\nAnalyse ces résultats de scan de vulnérabilités pour la cible: ${targetNetwork}\n\n=== RÉSULTATS DES SCANS ===\n\n🔐 SSL/TLS (${sslItems.length} issues):\n${sslItems.map(s => `- [${s.severity.toUpperCase()}] ${s.issue}: ${s.recommendation || ''}`).join('\\n') || 'Aucune anomalie SSL détectée'}\n\n📁 GOBUSTER (${gobusterItems.length} répertoires):\n${gobusterItems.map(g => `- ${g.path} (${g.status})`).join('\\n') || 'Aucun répertoire trouvé'}\n\n🌐 WHATWEB (${whatwebItems.length} technologies):\n${whatwebItems.map(w => `- ${w.technology} ${w.version ? `v${w.version}` : ''}`).join('\\n') || 'Aucune technologie détectée'}\n\n🎯 WPScan (${wpscanItems.length} vulnérabilités WordPress):\n${wpscanItems.filter(w => w.type !== 'info').map(w => `- [${w.severity.toUpperCase()}] ${w.component}: ${w.title || w.description || ''}`).join('\\n') || 'WordPress non détecté ou aucune vulnérabilité'}\n\n🔑 HYDRA (${hydraItems.filter(h => h.type === 'credential').length} credentials faibles):\n${hydraItems.filter(h => h.type === 'credential').map(h => `- ${h.service.toUpperCase()} (port ${h.port}): ${h.username}:${h.password}`).join('\\n') || 'Aucun mot de passe faible détecté'}\n\n🌐 NIKTO (${niktoItems.length} vulnérabilités web):\n${niktoItems.map(n => `- ${n.msg || n.id || n.description}`).join('\\n') || 'Aucune vulnérabilité Nikto'}\n\n=== DEMANDE D'ANALYSE ===\n\nRetourne UNIQUEMENT ce JSON valide (sans markdown, sans backticks):\n\n{\n  \"resume_executif\": \"Paragraphe professionnel en français (3-4 phrases) décrivant la posture de sécurité globale, les risques majeurs identifiés, et les priorités d'action immédiates.\",\n  \n  \"risque_global\": \"CRITIQUE | ÉLEVÉ | MOYEN | FAIBLE | INCONNU\",\n  \n  \"score_securite\": 0-100,\n  \n  \"vecteurs_attaque\": [\n    \"Vecteur d'attaque prioritaire 1\",\n    \"Vecteur d'attaque prioritaire 2\"\n  ],\n  \n  \"findings_valides\": [\n    {\n      \"id\": \"F001\",\n      \"titre\": \"Titre court du finding (max 60 caractères)\",\n      \"description\": \"Description technique claire du problème\",\n      \"faux_positif\": false,\n      \"severite\": \"CRITICAL | HIGH | MEDIUM | LOW | INFO\",\n      \"cvss_score\": 9.8,\n      \"cvss_vector\": \"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:H\",\n      \"cves\": [\"CVE-2024-XXXXX\"],\n      \"impact\": \"Description de l'impact potentiel sur la confidentialité, intégrité, disponibilité\",\n      \"remediation\": \"Étapes concrètes et précises pour corriger (commande, configuration, mise à jour)\",\n      \"source\": \"wpscan | sslscan | hydra | nikto | gobuster | whatweb\",\n      \"urgence\": \"IMMEDIATE | URGENT | NORMALE | PLANIFIEE\",\n      \"effort\": \"FACILE | MOYEN | DIFFICILE\"\n    }\n  ],\n  \n  \"stats\": {\n    \"total_findings\": 0,\n    \"critical\": 0,\n    \"high\": 0,\n    \"medium\": 0,\n    \"low\": 0,\n    \"info\": 0,\n    \"faux_positifs_filtres\": 0,\n    \"credentials_faibles\": 0,\n    \"services_critiques\": []\n  },\n  \n  \"recommandations_globales\": [\n    \"Recommandation stratégique 1\",\n    \"Recommandation stratégique 2\",\n    \"Recommandation stratégique 3\"\n  ],\n  \n  \"plan_action\": {\n    \"immediat\": [\"Action à réaliser dans les 24h\"],\n    \"court_terme\": [\"Action à réaliser dans la semaine\"],\n    \"moyen_terme\": [\"Action à réaliser dans le mois\"]\n  }\n}`;\n\ntry {\n    const response = await this.helpers.httpRequest({\n        method: 'POST',\n        url: 'https://api.groq.com/openai/v1/chat/completions',\n        headers: {\n            'Content-Type': 'application/json',\n            'Authorization': 'Bearer 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'\n        },\n        body: JSON.stringify({\n            model: 'llama-3.3-70b-versatile',\n            max_tokens: 8192,\n            temperature: 0.1,\n            top_p: 0.95,\n            messages: [\n                {\n                    role: 'system',\n                    content: 'Tu es un expert en cybersécurité avec 15 ans d\\'expérience. Tu retournes UNIQUEMENT du JSON valide, sans markdown, sans backticks. Tes analyses sont précises, concises et exploitables. Tu priorises les risques critiques et donnes des recommandations actionnables.'\n                },\n                {\n                    role: 'user',\n                    content: prompt\n                }\n            ]\n        }),\n        timeout: 90000\n    });\n\n    const rawText = response.choices[0].message.content;\n    console.log('Groq response length:', rawText.length);\n    console.log('Model used:', response.model);\n    \n    // Nettoyer et parser\n    const cleanText = rawText.replace(/```json|```/g, '').trim();\n    const aiAnalysis = JSON.parse(cleanText);\n    \n    // Validation et enrichissement\n    if (!aiAnalysis.score_securite) aiAnalysis.score_securite = 50;\n    if (!aiAnalysis.vecteurs_attaque) aiAnalysis.vecteurs_attaque = [];\n    if (!aiAnalysis.recommandations_globales) aiAnalysis.recommandations_globales = [];\n    if (!aiAnalysis.plan_action) aiAnalysis.plan_action = { immediat: [], court_terme: [], moyen_terme: [] };\n    \n    // Ajouter les statistiques manquantes\n    aiAnalysis.stats.credentials_faibles = hydraItems.filter(h => h.type === 'credential').length;\n    aiAnalysis.stats.services_critiques = [...new Set(\n        [...niktoItems, ...wpscanItems, ...sslItems]\n            .filter(item => item.severity === 'critical' || item.severity === 'high')\n            .map(item => item.url || item.host || targetNetwork)\n    )];\n    \n    console.log('✅ AI Analysis completed');\n    console.log(`   Risk level: ${aiAnalysis.risque_global}`);\n    console.log(`   Security score: ${aiAnalysis.score_securite}/100`);\n    console.log(`   Findings: ${aiAnalysis.stats.total_findings}`);\n    console.log(`   Weak credentials: ${aiAnalysis.stats.credentials_faibles}`);\n    \n    return [{ json: {\n        ...mergerData,\n        aiAnalysis,\n        aiSuccess: true,\n        aiModel: response.model,\n        analysisDate: new Date().toISOString()\n    }}];\n\n} catch(error) {\n    console.error('❌ Groq API error:', error.message);\n    \n    // Analyse de fallback (sans Nuclei)\n    const allFindings = [...niktoItems, ...wpscanItems, ...sslItems];\n    const criticalCount = allFindings.filter(f => f.severity === 'critical' || f.severity === 'CRITICAL').length;\n    const highCount = allFindings.filter(f => f.severity === 'high' || f.severity === 'HIGH').length;\n    const weakCreds = hydraItems.filter(h => h.type === 'credential').length;\n    \n    const fallbackAnalysis = {\n        resume_executif: `Analyse IA temporairement indisponible. Résumé basé sur les données brutes : ${allFindings.length} vulnérabilités détectées, ${weakCreds} mots de passe faibles trouvés. Prioriser la correction des mots de passe faibles et des vulnérabilités critiques.`,\n        risque_global: criticalCount > 0 ? 'CRITIQUE' : highCount > 0 ? 'ÉLEVÉ' : allFindings.length > 0 ? 'MOYEN' : 'FAIBLE',\n        score_securite: Math.max(0, 100 - (criticalCount * 15) - (highCount * 8) - (weakCreds * 10) - (allFindings.length * 2)),\n        vecteurs_attaque: weakCreds > 0 ? ['Attaque par force brute via mots de passe faibles'] : ['Vérifier les logs pour identifier les vecteurs exacts'],\n        findings_valides: allFindings.slice(0, 10).map((f, i) => ({\n            id: `F${String(i+1).padStart(3, '0')}`,\n            titre: f.id || f.issue || f.component || 'Vulnérabilité détectée',\n            description: f.description || f.msg || f.issue || 'Aucune description',\n            faux_positif: false,\n            severite: (f.severity?.toUpperCase() === 'CRITICAL' ? 'CRITICAL' :\n                       f.severity?.toUpperCase() === 'HIGH' ? 'HIGH' :\n                       f.severity?.toUpperCase() === 'MEDIUM' ? 'MEDIUM' : 'LOW'),\n            cvss_score: f.cvss_score || 0,\n            impact: weakCreds > 0 && f.type === 'credential' ? 'Compromission totale du compte' : 'Impact à évaluer',\n            remediation: f.remediation || f.recommendation || 'Appliquer les correctifs de sécurité',\n            source: f.tool || 'scan',\n            urgence: f.severity === 'critical' ? 'IMMEDIATE' : 'NORMALE',\n            effort: 'MOYEN'\n        })),\n        stats: {\n            total_findings: allFindings.length,\n            critical: criticalCount,\n            high: highCount,\n            medium: allFindings.filter(f => f.severity === 'medium' || f.severity === 'MEDIUM').length,\n            low: allFindings.filter(f => f.severity === 'low' || f.severity === 'LOW').length,\n            info: allFindings.filter(f => f.severity === 'info' || f.severity === 'INFO').length,\n            faux_positifs_filtres: 0,\n            credentials_faibles: weakCreds,\n            services_critiques: []\n        },\n        recommandations_globales: weakCreds > 0 ? [\n            'Changer immédiatement tous les mots de passe faibles détectés',\n            'Mettre à jour tous les logiciels identifiés comme vulnérables',\n            'Configurer correctement les en-têtes de sécurité'\n        ] : [\n            'Mettre à jour tous les logiciels identifiés comme vulnérables',\n            'Configurer correctement les en-têtes de sécurité',\n            'Réaliser un audit de sécurité complet'\n        ],\n        plan_action: {\n            immediat: weakCreds > 0 ? ['Changer les mots de passe compromis'] : [],\n            court_terme: ['Appliquer les correctifs de sécurité critiques'],\n            moyen_terme: ['Réaliser un audit de sécurité complet']\n        }\n    };\n    \n    return [{ json: {\n        ...mergerData,\n        aiAnalysis: fallbackAnalysis,\n        aiSuccess: false,\n        aiError: error.message,\n        analysisDate: new Date().toISOString()\n    }}];\n}"
      },
      "id": "98617ad6-a55e-4472-a2e9-9445d4f4dedd",
      "name": "Groq AI Analysis",
      "type": "n8n-nodes-base.code",
      "position": [
        2240,
        16
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst nmapJson = raw.stdout ? JSON.parse(raw.stdout) : raw;\n\nlet services = [];\nconst hosts = nmapJson.host || [];\n\nfor (const host of hosts) {\n    const ip = host.address?.[0]?.addr || 'unknown';\n    const ports = host.ports?.port || [];\n\n    for (const portObj of ports) {\n        if (portObj.state?.state !== 'open') continue;\n        const serviceObj = portObj.service || {};\n\n        let cpe = '';\n        if (Array.isArray(serviceObj.cpe) && serviceObj.cpe.length > 0) {\n            const rawCpe = serviceObj.cpe[0];\n            if (rawCpe.startsWith('cpe:/')) {\n                cpe = 'cpe:2.3:' + rawCpe.slice(5).replace(/\\//g, ':');\n                const parts = cpe.split(':');\n                while (parts.length < 13) parts.push('*');\n                cpe = parts.slice(0, 13).join(':');\n            } else {\n                cpe = rawCpe;\n            }\n        }\n\n        services.push({\n            ip, port: portObj.portid, protocol: portObj.protocol,\n            service: serviceObj.name || 'unknown',\n            product: serviceObj.product || '',\n            version: serviceObj.version || '',\n            cpe,\n            serviceKey: `${ip}:${portObj.portid}`\n        });\n    }\n}\n\nconsole.log(`✓ Parsed ${services.length} open services`);\nreturn [{ json: { services } }];"
      },
      "id": "8fb84648-876a-4339-844a-70b462580247",
      "name": "3. Parser les Services",
      "type": "n8n-nodes-base.code",
      "position": [
        2432,
        16
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const services = $input.first().json.services;\nconst enriched = [];\n\nconsole.log('=== CVE ENRICHMENT START ===');\nconsole.log(`Processing ${services.length} services`);\n\nfor (let i = 0; i < services.length; i++) {\n    const service = services[i];\n    const base = { ...service };\n\n    if (!base.cpe || base.cpe.trim() === '' || base.cpe === ':') {\n        enriched.push({ ...base, cveId: 'N/A', cveSummary: 'No CPE available', cvssScore: 0, severity: 'INFO' });\n        continue;\n    }\n\n    try {\n        const vendor = base.cpe.split(':')[3] || '';\n        const product = base.cpe.split(':')[4] || '';\n        const version = base.cpe.split(':')[5] || '';\n\n        let apiUrl = version && version !== '*'\n            ? `https://services.nvd.nist.gov/rest/json/cves/2.0?cpeName=${encodeURIComponent(base.cpe)}&resultsPerPage=20`\n            : `https://services.nvd.nist.gov/rest/json/cves/2.0?keywordSearch=${encodeURIComponent(vendor + ' ' + product)}&resultsPerPage=20`;\n\n        console.log(`[${i+1}/${services.length}] Querying: ${base.cpe}`);\n\n        const response = await this.helpers.httpRequest({\n            method: 'GET',\n            url: apiUrl,\n            timeout: 30000,\n            headers: { 'User-Agent': 'n8n-vulnerability-scanner/2.0' }\n        });\n\n        const vulnerabilities = response.vulnerabilities || [];\n        console.log(`-> Found ${vulnerabilities.length} CVEs`);\n\n        if (vulnerabilities.length === 0) {\n            enriched.push({ ...base, cveId: 'N/A', cveSummary: 'No known vulnerabilities found', cvssScore: 0, severity: 'INFO' });\n        } else {\n            for (const vuln of vulnerabilities) {\n                const cve = vuln.cve || {};\n                const cveId = cve.id || 'UNKNOWN';\n                const cveSummary = (cve.descriptions || []).find(d => d.lang === 'en')?.value || 'No description';\n                const metrics = cve.metrics || {};\n                const metricV31 = metrics.cvssMetricV31?.[0];\n                const metricV30 = metrics.cvssMetricV30?.[0];\n                const metricV2 = metrics.cvssMetricV2?.[0];\n                const bestMetric = metricV31 || metricV30 || metricV2;\n                const cvssData = bestMetric?.cvssData || {};\n                const cvssScore = cvssData.baseScore || 0;\n                const severity = cvssData.baseSeverity || metricV2?.baseSeverity || 'UNKNOWN';\n                const publishedDate = cve.published || 'N/A';\n                \n                enriched.push({ ...base, cveId, cveSummary, cvssScore, severity, publishedDate });\n            }\n        }\n\n    } catch (error) {\n        console.error(`Error: ${error.message}`);\n        enriched.push({ ...base, cveId: 'N/A', cveSummary: `API Error: ${error.message}`, cvssScore: 0, severity: 'ERROR' });\n    }\n\n    if (i < services.length - 1) {\n        console.log('Waiting 6s...');\n        await new Promise(r => setTimeout(r, 6000));\n    }\n}\n\nconsole.log(`=== CVE ENRICHMENT COMPLETE: ${enriched.length} results ===`);\nreturn [{ json: { enriched } }];"
      },
      "id": "89bbb33c-227e-4c3e-ba24-0077084f34a0",
      "name": "4. Enrichissement CVE",
      "type": "n8n-nodes-base.code",
      "position": [
        2608,
        16
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst targetNetwork = $('1. Préparer les Paramètres').first().json.network;\nconst timestamp = $('1. Préparer les Paramètres').first().json.timestamp;\nconst mergerData = $('Groq AI Analysis').first().json;\nconst aiAnalysis = mergerData.aiAnalysis || {};\n\nconst niktoItems = mergerData.niktoResults || [];\nconst sslItems = mergerData.sslResults || [];\nconst whatwebItems = mergerData.whatwebResults || [];\nconst gobusterItems = mergerData.gobusterResults || [];\nconst wpscanItems = mergerData.wpscanResults || [];\nconst hydraItems = mergerData.hydraResults || [];\nconst hydraCredentials = hydraItems.filter(r => r.type === 'credential').length;\nconst securityScore = aiAnalysis.score_securite || 50;\nconst scoreColor = securityScore >= 80 ? '#27ae60' : securityScore >= 50 ? '#f39c12' : '#c0392b';\nconst cveItems = input.enriched || [];\nconst serviceMap = {};\n\ncveItems.forEach(data => {\n    const key = data.serviceKey || `${data.ip}:${data.port}`;\n    if (!serviceMap[key]) {\n        serviceMap[key] = { \n            ip: data.ip, \n            port: data.port, \n            protocol: data.protocol, \n            service: data.service, \n            product: data.product, \n            version: data.version, \n            cpe: data.cpe, \n            cves: [] \n        };\n    }\n    if (data.cveId && data.cveId !== 'N/A') {\n        serviceMap[key].cves.push({\n            id: data.cveId,\n            summary: data.cveSummary,\n            severity: data.severity || 'UNKNOWN',\n            score: data.cvssScore || 'N/A',\n            published: (data.publishedDate || 'N/A').substring(0, 10)\n        });\n    }\n});\n\nconst services = Object.values(serviceMap).sort((a, b) => b.cves.length - a.cves.length);\n\n// Statistiques Nikto\nconst niktoCritical = niktoItems.filter(f => f.msg?.toLowerCase().includes('critical') || f.msg?.toLowerCase().includes('osvdb')).length;\nconst niktoHigh = niktoItems.filter(f => f.msg?.toLowerCase().includes('high') || f.msg?.includes('vulnerable')).length;\nconst niktoMedium = niktoItems.filter(f => f.msg?.toLowerCase().includes('medium') || f.msg?.includes('warning')).length;\nconst niktoInfo = niktoItems.filter(f => f.type === 'info' || f.id === 'NO_ISSUES').length;\n\nconst aiStats = aiAnalysis.stats || {};\nconst totalCVEs = aiStats.total_findings || 0;\nconst criticalCount = aiStats.critical || 0;\nconst highCount = aiStats.high || 0;\nconst mediumCount = aiStats.medium || 0;\nconst lowCount = aiStats.low || 0;\nconst scanDate = new Date().toLocaleString('fr-FR');\n\nconst riskColor = {\n    'CRITIQUE': '#c0392b', 'ÉLEVÉ': '#e67e22', 'MOYEN': '#f39c12',\n    'FAIBLE': '#27ae60', 'INCONNU': '#95a5a6'\n}[aiAnalysis.risque_global] || '#95a5a6';\n\nconst aiResumeSection = aiAnalysis.resume_executif ? `\n<div style=\"background:#f8f9ff;border-left:5px solid #8e44ad;padding:20px;margin:20px 0;border-radius:0 8px 8px 0;\">\n    <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:12px;\">\n        <h3 style=\"color:#8e44ad;margin:0;\">🤖 Analyse IA — Résumé Exécutif</h3>\n        <span style=\"background:${riskColor};color:white;padding:3px 12px;border-radius:10px;font-size:12px;font-weight:bold;\">\n            RISQUE ${aiAnalysis.risque_global || 'INCONNU'}\n        </span>\n    </div>\n    <p style=\"color:#444;font-size:14px;line-height:1.7;\">${aiAnalysis.resume_executif}</p>\n</div>` : '';\n\nconst aiFindingsSection = (aiAnalysis.findings_valides || []).length > 0 ? `\n<h2>🤖 Findings Validés par IA — ${aiAnalysis.findings_valides.length} résultats</h2>\n${aiAnalysis.findings_valides.map((f, idx) => {\n    const sev = (f.severite || 'info').toLowerCase();\n    const borderColor = sev === 'critical' ? '#c0392b' : sev === 'high' ? '#e67e22' : sev === 'medium' ? '#f39c12' : sev === 'low' ? '#27ae60' : '#95a5a6';\n    const badgeCls = sev === 'critical' ? 'bg-critical' : sev === 'high' ? 'bg-high' : sev === 'medium' ? 'bg-medium' : sev === 'low' ? 'bg-low' : 'bg-unknown';\n    return `\n<div class=\"service\" style=\"border-left-color:${borderColor};\">\n    <div class=\"service-header\">\n        <div>\n            <div class=\"service-title\">${f.id} — ${f.titre}</div>\n            <div class=\"service-details\">${f.description}</div>\n            ${f.impact ? `<div class=\"service-details\" style=\"color:#e74c3c;\">⚠️ Impact: ${f.impact}</div>` : ''}\n        </div>\n        <div style=\"text-align:right;\">\n            <span class=\"badge ${badgeCls}\">${f.severite}</span>\n            ${f.cvss_score ? `<div style=\"font-size:20px;font-weight:bold;color:${borderColor};margin-top:4px;\">${f.cvss_score}</div>` : ''}\n        </div>\n    </div>\n    <div style=\"background:#fff9f0;border:1px solid #fde8c8;border-radius:4px;padding:10px;margin-top:10px;\">\n        <strong style=\"font-size:12px;color:#e67e22;\">🔧 Remédiation:</strong>\n        <p style=\"font-size:13px;color:#555;margin-top:4px;\">${f.remediation}</p>\n    </div>\n</div>`; }).join('')}` : '';\n\n// Section NIKTO\nconst niktoSection = niktoItems.length > 0 && niktoItems[0].id !== 'NO_ISSUES' ? `\n<h2>🔍 Vulnérabilités Web (Nikto) — ${niktoItems.length} issues</h2>\n<div style=\"display:flex;gap:10px;margin:15px 0;flex-wrap:wrap;\">\n    ${niktoCritical > 0 ? `<span style=\"background:#c0392b;color:white;padding:5px 15px;border-radius:20px;\">Critique: ${niktoCritical}</span>` : ''}\n    ${niktoHigh > 0 ? `<span style=\"background:#e67e22;color:white;padding:5px 15px;border-radius:20px;\">Élevé: ${niktoHigh}</span>` : ''}\n    ${niktoMedium > 0 ? `<span style=\"background:#f39c12;color:#333;padding:5px 15px;border-radius:20px;\">Moyen: ${niktoMedium}</span>` : ''}\n    ${niktoInfo > 0 ? `<span style=\"background:#3498db;color:white;padding:5px 15px;border-radius:20px;\">Info: ${niktoInfo}</span>` : ''}\n</div>\n${niktoItems.filter(f => f.id !== 'NO_ISSUES').map((f, idx) => {\n    const severity = f.msg?.toLowerCase().includes('critical') ? 'critical' :\n                     f.msg?.toLowerCase().includes('high') ? 'high' :\n                     f.msg?.toLowerCase().includes('medium') ? 'medium' : 'info';\n    const borderColor = severity === 'critical' ? '#c0392b' : \n                        severity === 'high' ? '#e67e22' : \n                        severity === 'medium' ? '#f39c12' : '#3498db';\n    const badgeCls = severity === 'critical' ? 'bg-critical' : \n                     severity === 'high' ? 'bg-high' : \n                     severity === 'medium' ? 'bg-medium' : 'bg-info';\n    \n    return `\n<div class=\"service\" style=\"border-left-color:${borderColor};\">\n    <div class=\"service-header\">\n        <div>\n            <div class=\"service-title\">${f.id || 'Finding ' + (idx+1)}</div>\n            <div class=\"service-details\">${f.msg || 'No description'}</div>\n            <div class=\"service-details\">URL: ${f.url || targetNetwork}</div>\n            ${f.method ? `<div class=\"service-details\">Méthode: ${f.method}</div>` : ''}\n        </div>\n        <div style=\"text-align:right;\">\n            <span class=\"badge ${badgeCls}\">${severity.toUpperCase()}</span>\n        </div>\n    </div>\n    ${f.remediation ? `\n    <div style=\"background:#fff9f0;border:1px solid #fde8c8;border-radius:4px;padding:10px;margin-top:10px;\">\n        <strong style=\"font-size:12px;color:#e67e22;\">🔧 Remédiation:</strong>\n        <p style=\"font-size:13px;color:#555;margin-top:4px;\">${f.remediation}</p>\n    </div>` : ''}\n</div>`; }).join('')}\n` : '';\n\n// Section SSL\nconst sslSection = sslItems.length > 0 ? `\n<h2>🔐 Analyse SSL/TLS — ${sslItems.length} issues</h2>\n${sslItems.map(s => {\n    const sev = (s.severity || 'info').toLowerCase();\n    const borderColor = sev === 'critical' ? '#c0392b' : sev === 'high' ? '#e67e22' : sev === 'medium' ? '#f39c12' : '#27ae60';\n    return `\n<div class=\"service\" style=\"border-left-color:${borderColor};\">\n    <div class=\"service-header\">\n        <div>\n            <div class=\"service-title\">${s.issue || 'SSL Issue'}</div>\n            <div class=\"service-details\">${s.recommendation || ''}</div>\n        </div>\n        <span class=\"badge bg-${sev}\">${s.severity || 'INFO'}</span>\n    </div>\n</div>`; }).join('')}` : '';\n\n// Section WhatWeb\nconst techSection = whatwebItems.length > 0 ? `\n<h2>🌐 Technologies Détectées (WhatWeb) — ${whatwebItems.length} technologies</h2>\n<table style=\"width:100%;border-collapse:collapse;margin:10px 0;font-size:13px;\">\n    <tr style=\"background:#2c3e50;color:white;\">\n        <td style=\"padding:8px;\">Technologie</td>\n        <td style=\"padding:8px;\">Version</td>\n        <td style=\"padding:8px;\">Détails</td>\n    </tr>\n    ${whatwebItems.map((w, i) => `\n    <tr style=\"background:${i%2===0?'#f8f9fa':'white'};\">\n        <td style=\"padding:8px;font-weight:bold;\">${w.technology || w.name || 'Unknown'}</td>\n        <td style=\"padding:8px;\">${w.version || 'N/A'}</td>\n        <td style=\"padding:8px;\">${w.string || w.details || ''}</td>\n    </tr>`).join('')}\n</table>` : '';\n\n// Section Gobuster\nconst dirSection = gobusterItems.length > 0 ? `\n<h2>📁 Répertoires Trouvés (Gobuster) — ${gobusterItems.length} chemins</h2>\n<table style=\"width:100%;border-collapse:collapse;margin:10px 0;font-size:13px;\">\n    <tr style=\"background:#2c3e50;color:white;\">\n        <td style=\"padding:8px;\">Chemin</td>\n        <td style=\"padding:8px;\">Status</td>\n        <td style=\"padding:8px;\">Taille</td>\n    </tr>\n    ${gobusterItems.map((g, i) => `\n    <tr style=\"background:${i%2===0?'#f8f9fa':'white'};\">\n        <td style=\"padding:8px;\"><code>${g.path || g.url || 'N/A'}</code></td>\n        <td style=\"padding:8px;font-weight:bold;color:${g.status==='200'?'#27ae60':g.status==='403'?'#e74c3c':'#f39c12'}\">${g.status || 'N/A'}</td>\n        <td style=\"padding:8px;\">${g.size || g.length || 'N/A'}</td>\n    </tr>`).join('')}\n</table>` : '';\n// Section WPScan\nconst wpscanSection = wpscanItems && wpscanItems.length > 0 ? `\n<h2>🎯 Vulnérabilités WordPress (WPScan) — ${wpscanItems.filter(r => r.type !== 'info').length} issues</h2>\n<div style=\"display:flex;gap:10px;margin:15px 0;flex-wrap:wrap;\">\n    ${wpscanItems.filter(f => f.severity === 'critical').length > 0 ? \n        `<span style=\"background:#c0392b;color:white;padding:5px 15px;border-radius:20px;\">Critique: ${wpscanItems.filter(f => f.severity === 'critical').length}</span>` : ''}\n    ${wpscanItems.filter(f => f.severity === 'high').length > 0 ? \n        `<span style=\"background:#e67e22;color:white;padding:5px 15px;border-radius:20px;\">Élevé: ${wpscanItems.filter(f => f.severity === 'high').length}</span>` : ''}\n    ${wpscanItems.filter(f => f.severity === 'medium').length > 0 ? \n        `<span style=\"background:#f39c12;color:#333;padding:5px 15px;border-radius:20px;\">Moyen: ${wpscanItems.filter(f => f.severity === 'medium').length}</span>` : ''}\n    ${wpscanItems.filter(f => f.severity === 'low').length > 0 ? \n        `<span style=\"background:#27ae60;color:white;padding:5px 15px;border-radius:20px;\">Faible: ${wpscanItems.filter(f => f.severity === 'low').length}</span>` : ''}\n</div>\n${wpscanItems.filter(f => f.type !== 'info').map(f => {\n    const sev = (f.severity || 'info').toLowerCase();\n    const borderColor = sev === 'critical' ? '#c0392b' : \n                       sev === 'high' ? '#e67e22' : \n                       sev === 'medium' ? '#f39c12' : \n                       sev === 'low' ? '#27ae60' : '#95a5a6';\n    const badgeCls = sev === 'critical' ? 'bg-critical' : \n                    sev === 'high' ? 'bg-high' : \n                    sev === 'medium' ? 'bg-medium' : \n                    sev === 'low' ? 'bg-low' : 'bg-unknown';\n    \n    return `\n<div class=\"service\" style=\"border-left-color:${borderColor};\">\n    <div class=\"service-header\">\n        <div>\n            <div class=\"service-title\">${f.component || f.id} — ${f.title || 'Vulnerability'}</div>\n            ${f.version ? `<div class=\"service-details\">Version: ${f.version}</div>` : ''}\n            <div class=\"service-details\">${f.description || 'No description'}</div>\n        </div>\n        <div style=\"text-align:right;\">\n            <span class=\"badge ${badgeCls}\">${f.severity ? f.severity.toUpperCase() : 'INFO'}</span>\n            ${f.cvss_score ? `<div style=\"font-size:20px;font-weight:bold;color:${borderColor};\">${f.cvss_score}</div>` : ''}\n        </div>\n    </div>\n    <div style=\"background:#fff9f0;border:1px solid #fde8c8;border-radius:4px;padding:10px;margin-top:10px;\">\n        <strong style=\"font-size:12px;color:#e67e22;\">🔧 Remédiation:</strong>\n        <p style=\"font-size:13px;color:#555;margin-top:4px;\">${f.remediation || 'Update to latest version'}</p>\n    </div>\n    ${f.references && f.references.length > 0 ? `\n    <div style=\"margin-top:8px;font-size:11px;\">\n        <strong>Références:</strong> ${f.references.slice(0, 3).map(r => `<a href=\"${r.url || r}\" target=\"_blank\">${r.url ? r.url.substring(0, 40) : r.substring(0, 40)}...</a>`).join(', ')}\n    </div>` : ''}\n</div>`; }).join('')}\n` : '';\nconst hydraSection = hydraItems && hydraItems.filter(r => r.type === 'credential').length > 0 ? `\n<h2>🔑 Identifiants Faibles Détectés (Hydra) — ${hydraItems.filter(r => r.type === 'credential').length} credentials</h2>\n<div style=\"background:#fff5f5;border-left:5px solid #c0392b;padding:20px;margin:20px 0;border-radius:0 8px 8px 0;\">\n    <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:15px;\">\n        <span style=\"font-size:24px;\">⚠️</span>\n        <strong style=\"color:#c0392b;\">CRITICAL - Weak credentials found!</strong>\n    </div>\n    ${hydraItems.filter(r => r.type === 'credential').map(f => `\n    <div class=\"service\" style=\"border-left-color:#c0392b;background:#fff0f0;\">\n        <div class=\"service-header\">\n            <div>\n                <div class=\"service-title\">${f.service.toUpperCase()} (Port ${f.port})</div>\n                <div class=\"service-details\"><strong>Username:</strong> ${f.username}</div>\n                <div class=\"service-details\"><strong>Password:</strong> <span style=\"background:#eee;padding:2px 8px;border-radius:4px;font-family:monospace;\">${f.password}</span></div>\n                <div class=\"service-details\">${f.description}</div>\n            </div>\n            <span class=\"badge bg-critical\">CRITICAL</span>\n        </div>\n        <div style=\"background:#fff0e0;border:1px solid #fde8c8;border-radius:4px;padding:10px;margin-top:10px;\">\n            <strong style=\"font-size:12px;color:#e67e22;\">🔧 Remédiation:</strong>\n            <p style=\"font-size:13px;color:#555;margin-top:4px;\">${f.remediation}</p>\n        </div>\n    </div>`).join('')}\n</div>\n` : '';\nconst scoreSection = `\n<div style=\"background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px; padding: 20px; margin: 20px 0; color: white;\">\n    <div style=\"display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;\">\n        <div>\n            <h3 style=\"margin: 0 0 8px 0;\">📊 Score de Sécurité Global</h3>\n            <div style=\"font-size: 48px; font-weight: bold;\">${securityScore}/100</div>\n            <div style=\"font-size: 14px; opacity: 0.9;\">${securityScore >= 80 ? '✅ Bonne posture' : securityScore >= 50 ? '⚠️ Risques modérés' : '🔴 Risques critiques'}</div>\n        </div>\n        <div style=\"background: ${scoreColor}; padding: 15px 25px; border-radius: 50px;\">\n            <div style=\"font-size: 14px;\">Niveau de risque</div>\n            <div style=\"font-size: 24px; font-weight: bold;\">${aiAnalysis.risque_global || 'INCONNU'}</div>\n        </div>\n    </div>\n</div>`;\nconst vectorsSection = aiAnalysis.vecteurs_attaque && aiAnalysis.vecteurs_attaque.length > 0 ? `\n<h2>🎯 Vecteurs d'Attaque Prioritaires</h2>\n<div style=\"display: flex; gap: 15px; flex-wrap: wrap; margin: 15px 0;\">\n    ${aiAnalysis.vecteurs_attaque.map(v => `\n    <div style=\"background: #f8f9fa; border-left: 4px solid #e74c3c; padding: 12px 20px; border-radius: 8px;\">\n        <span style=\"font-weight: bold;\">⚠️ ${v}</span>\n    </div>`).join('')}\n</div>\n` : '';\nconst actionPlanSection = aiAnalysis.plan_action ? `\n<h2>📋 Plan d'Action Recommandé</h2>\n<div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin: 20px 0;\">\n    <div style=\"background: #ffe5e5; padding: 15px; border-radius: 8px;\">\n        <h3 style=\"color: #c0392b; margin-bottom: 12px;\">🚨 IMMÉDIAT (24h)</h3>\n        <ul style=\"margin-left: 20px;\">\n            ${(aiAnalysis.plan_action.immediat || []).map(a => `<li>${a}</li>`).join('') || '<li>Aucune action immédiate requise</li>'}\n        </ul>\n    </div>\n    <div style=\"background: #fff0e0; padding: 15px; border-radius: 8px;\">\n        <h3 style=\"color: #e67e22; margin-bottom: 12px;\">📅 COURT TERME (1 semaine)</h3>\n        <ul style=\"margin-left: 20px;\">\n            ${(aiAnalysis.plan_action.court_terme || []).map(a => `<li>${a}</li>`).join('') || '<li>Aucune action court terme</li>'}\n        </ul>\n    </div>\n    <div style=\"background: #e8f5e9; padding: 15px; border-radius: 8px;\">\n        <h3 style=\"color: #27ae60; margin-bottom: 12px;\">📈 MOYEN TERME (1 mois)</h3>\n        <ul style=\"margin-left: 20px;\">\n            ${(aiAnalysis.plan_action.moyen_terme || []).map(a => `<li>${a}</li>`).join('') || '<li>Aucune action moyen terme</li>'}\n        </ul>\n    </div>\n</div>\n` : '';\nconst globalRecosSection = aiAnalysis.recommandations_globales && aiAnalysis.recommandations_globales.length > 0 ? `\n<h2>💡 Recommandations Stratégiques</h2>\n<div style=\"background: #f0f7ff; padding: 20px; border-radius: 8px; margin: 15px 0;\">\n    <ul style=\"margin-left: 20px;\">\n        ${aiAnalysis.recommandations_globales.map(r => `<li style=\"margin: 8px 0;\">${r}</li>`).join('')}\n    </ul>\n</div>\n` : '';\n// Construction finale du HTML\nconst htmlReport = `<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<title>Rapport de Vulnérabilités — ${targetNetwork}</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { font-family: 'Segoe UI', Arial, sans-serif; background: #f5f5f5; padding: 20px; color: #333; }\n.container { max-width: 1200px; margin: 0 auto; background: white; padding: 40px; box-shadow: 0 2px 15px rgba(0,0,0,0.1); }\n.header { border-bottom: 4px solid #8e44ad; padding-bottom: 20px; margin-bottom: 30px; }\n.header h1 { color: #2c3e50; font-size: 30px; margin-bottom: 8px; }\n.meta { color: #7f8c8d; font-size: 13px; }\nh2 { color: #2c3e50; font-size: 20px; margin: 30px 0 15px 0; border-bottom: 1px solid #ecf0f1; padding-bottom: 8px; }\n.summary-table { width: 100%; border-collapse: separate; border-spacing: 10px; margin: 15px 0 30px 0; }\n.summary-table td { text-align: center; padding: 20px 10px; border-radius: 8px; width: 14%; }\n.stat-num { font-size: 38px; font-weight: bold; display: block; line-height: 1; }\n.stat-lbl { font-size: 12px; display: block; margin-top: 6px; }\n.box-blue { background-color: #2980b9; color: white; }\n.box-red { background-color: #c0392b; color: white; }\n.box-orange { background-color: #d35400; color: white; }\n.box-yellow { background-color: #e67e22; color: #333; }\n.box-green { background-color: #27ae60; color: white; }\n.box-purple { background-color: #8e44ad; color: white; }\n.service { background: #f8f9fa; border-left: 5px solid #3498db; padding: 18px 20px; margin: 18px 0; border-radius: 0 4px 4px 0; }\n.service-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; padding-bottom: 10px; border-bottom: 1px solid #ddd; }\n.service-title { font-size: 17px; font-weight: bold; color: #2c3e50; }\n.service-details { font-size: 13px; color: #666; margin-top: 4px; }\n.cve-card { background: white; border: 1px solid #e0e0e0; border-radius: 4px; padding: 14px 16px; margin: 10px 0; }\n.cve-id { font-weight: bold; color: #2980b9; font-size: 14px; margin-right: 10px; }\n.cve-summary { font-size: 13px; color: #666; margin-top: 6px; }\n.badge { display: inline-block; padding: 3px 10px; border-radius: 10px; font-size: 11px; font-weight: bold; }\n.bg-critical { background-color: #c0392b; color: white; }\n.bg-high { background-color: #e67e22; color: white; }\n.bg-medium { background-color: #f39c12; color: #333; }\n.bg-low { background-color: #27ae60; color: white; }\n.bg-info { background-color: #3498db; color: white; }\n.bg-unknown { background-color: #95a5a6; color: white; }\n.footer { margin-top: 40px; padding-top: 20px; border-top: 2px solid #ecf0f1; text-align: center; color: #aaa; font-size: 12px; }\ntable { width: 100%; border-collapse: collapse; }\ntd { padding: 8px; border: 1px solid #ddd; }\ntr:first-child td { font-weight: bold; background-color: #2c3e50; color: white; }\n</style>\n</head>\n<body>\n<div class=\"container\">\n\n    <div class=\"header\">\n        <h1>🔒 Rapport de Vulnérabilités — AI Enhanced</h1>\n        <div class=\"meta\">\n            <strong>Cible :</strong> ${targetNetwork} &nbsp;|&nbsp;\n            <strong>Date :</strong> ${scanDate} &nbsp;|&nbsp;\n            <strong>ID :</strong> ${timestamp}\n        </div>\n    </div>\n\n    ${aiResumeSection}\n\n    <h2>📊 Résumé Exécutif</h2>\n    <table class=\"summary-table\">\n        <tr>\n            <td class=\"box-blue\"><span class=\"stat-num\">${services.length}</span><span class=\"stat-lbl\">Services</span></td>\n            <td class=\"box-red\"><span class=\"stat-num\">${criticalCount}</span><span class=\"stat-lbl\">Critiques</span></td>\n            <td class=\"box-orange\"><span class=\"stat-num\">${highCount}</span><span class=\"stat-lbl\">Élevés</span></td>\n            <td class=\"box-yellow\"><span class=\"stat-num\">${mediumCount}</span><span class=\"stat-lbl\">Moyens</span></td>\n            <td class=\"box-green\"><span class=\"stat-num\">${lowCount}</span><span class=\"stat-lbl\">Faibles</span></td>\n            <td class=\"box-purple\"><span class=\"stat-num\">${niktoItems.filter(f => f.id !== 'NO_ISSUES').length}</span><span class=\"stat-lbl\">Nikto</span></td>\n            <td class=\"box-purple\"><span class=\"stat-num\">${aiAnalysis.stats?.faux_positifs_filtres || 0}</span><span class=\"stat-lbl\">Faux positifs</span></td>\n            <td class=\"box-red\"><span class=\"stat-num\">${hydraCredentials}</span><span class=\"stat-lbl\">Creds Faibles</span></td>\n        </tr>\n    </table>\n\n    ${aiFindingsSection}\n\n    ${niktoSection}\n\n    <h2>🛡️ Services & CVEs Détectés</h2>\n    ${services.map(s => {\n        const badgeClass = s.cves.length > 5 ? 'bg-critical' : s.cves.length > 0 ? 'bg-high' : 'bg-low';\n        return `\n    <div class=\"service\">\n        <div class=\"service-header\">\n            <div>\n                <div class=\"service-title\">${s.ip}:${s.port}/${s.protocol}</div>\n                <div class=\"service-details\"><strong>${s.service}</strong>${s.product ? ' - ' + s.product : ''} ${s.version}</div>\n            </div>\n            <span class=\"badge ${badgeClass}\">${s.cves.length} CVEs</span>\n        </div>\n        ${s.cves.length > 0 ? s.cves.map(c => `\n        <div class=\"cve-card\">\n            <span class=\"cve-id\">${c.id}</span>\n            <span class=\"badge bg-${(c.severity || 'unknown').toLowerCase()}\">${c.severity}</span>\n            <div class=\"cve-summary\">${c.summary}</div>\n        </div>`).join('') : '<p>Aucune CVE connue</p>'}\n    </div>`;}).join('')}\n\n    ${sslSection}\n    ${techSection}\n    ${dirSection}\n    ${wpscanSection} \n    ${hydraSection} \n    ${scoreSection}\n    ${vectorsSection}\n    ${actionPlanSection}\n    ${globalRecosSection}\n\n    <div class=\"footer\">\n        <p><strong>n8n Vulnerability Scanner v2 — Ubuntu Edition</strong> &nbsp;|&nbsp; ${new Date().toISOString()}</p>\n        <p style=\"margin-top:5px;\">🔍 Nikto | 🔐 SSLScan | 🌐 WhatWeb | 📁 Gobuster | 🛡️ Nmap + CVE</p>\n    </div>\n\n</div>\n</body>\n</html>`;\n\nreturn [{ json: { html: htmlReport, filename: `vulnerability_report_${timestamp}.html`, targetNetwork, timestamp } }];"
