    {
      "parameters": {
        "jsCode": "const { exec } = require('child_process');\nconst util = require('util');\nconst execPromise = util.promisify(exec);\nconst fs = require('fs');\n\nconst network = $('Extraire Ports Ouverts').first().json.network;\nconst openPorts = $('Extraire Ports Ouverts').first().json.openPorts || [];\nconst timestamp = $('Extraire Ports Ouverts').first().json.timestamp;\nconst tempDir = '/tmp/vulnscan';\nconst outputFile = `${tempDir}/hydra_${timestamp}.txt`;\n\nconsole.log('🔓 Starting Hydra brute-force scan on:', network);\nconsole.log('Open ports detected:', openPorts);\n\nlet hydraResults = [];\n\n// Ne pas bruteforcer si trop de ports (évite les scans trop longs)\nif (openPorts.length > 10) {\n    console.log('⚠️ Too many open ports, skipping Hydra to avoid long scan');\n    hydraResults.push({\n        tool: 'hydra',\n        type: 'info',\n        id: 'SKIPPED',\n        severity: 'info',\n        description: 'Hydra skipped due to too many open ports (>10)',\n        url: network\n    });\n    return [{ json: { hydraResults } }];\n}\n\ntry {\n    // Créer le dossier temporaire\n    if (!fs.existsSync(tempDir)) {\n        fs.mkdirSync(tempDir, { recursive: true });\n    }\n    \n    // Dictionnaires de mots de passe communs\n    const commonPasswords = [\n        'password', '123456', 'admin', 'root', 'toor', 'qwerty', \n        'abc123', 'letmein', 'welcome', 'admin123', 'password123'\n    ];\n    const commonUsers = ['root', 'admin', 'user', 'test', 'ubuntu', 'admin', 'user1'];\n    \n    // Écrire les dictionnaires dans des fichiers temporaires\n    const passFile = `${tempDir}/passwords_${timestamp}.txt`;\n    const userFile = `${tempDir}/users_${timestamp}.txt`;\n    \n    fs.writeFileSync(passFile, commonPasswords.join('\\n'));\n    fs.writeFileSync(userFile, commonUsers.join('\\n'));\n    \n    // Déterminer quels services attaquer\n    const servicesToScan = [];\n    \n    // SSH sur port 22\n    if (openPorts.includes(22)) {\n        servicesToScan.push({ service: 'ssh', port: 22 });\n    }\n    \n    // FTP sur port 21\n    if (openPorts.includes(21)) {\n        servicesToScan.push({ service: 'ftp', port: 21 });\n    }\n    \n    // HTTP Basic Auth (port 80/443)\n    if (openPorts.includes(80) || openPorts.includes(443)) {\n        servicesToScan.push({ service: 'http-get', port: openPorts.includes(443) ? 443 : 80, path: '/' });\n    }\n    \n    // MySQL sur port 3306\n    if (openPorts.includes(3306)) {\n        servicesToScan.push({ service: 'mysql', port: 3306 });\n    }\n    \n    // PostgreSQL sur port 5432\n    if (openPorts.includes(5432)) {\n        servicesToScan.push({ service: 'postgres', port: 5432 });\n    }\n    \n    // RDP sur port 3389\n    if (openPorts.includes(3389)) {\n        servicesToScan.push({ service: 'rdp', port: 3389 });\n    }\n    \n    console.log('Services to brute-force:', servicesToScan.map(s => s.service).join(', '));\n    \n    // Scanner chaque service\n    for (const target of servicesToScan) {\n        console.log(`🔑 Brute-forcing ${target.service} on port ${target.port}...`);\n        \n        let cmd = '';\n        let serviceName = target.service;\n        \n        switch (target.service) {\n            case 'ssh':\n                cmd = `hydra -L ${userFile} -P ${passFile} ssh://${network}:${target.port} -t 4 -o ${outputFile}.ssh -f -v -I`;\n                break;\n            case 'ftp':\n                cmd = `hydra -L ${userFile} -P ${passFile} ftp://${network}:${target.port} -t 4 -o ${outputFile}.ftp -f -v -I`;\n                break;\n            case 'http-get':\n                cmd = `hydra -L ${userFile} -P ${passFile} http-get://${network}:${target.port}${target.path} -o ${outputFile}.http -f -v -I`;\n                break;\n            case 'mysql':\n                cmd = `hydra -L ${userFile} -P ${passFile} mysql://${network}:${target.port} -t 4 -o ${outputFile}.mysql -f -v -I`;\n                break;\n            case 'postgres':\n                cmd = `hydra -L ${userFile} -P ${passFile} postgres://${network}:${target.port} -t 4 -o ${outputFile}.postgres -f -v -I`;\n                break;\n            case 'rdp':\n                cmd = `hydra -L ${userFile} -P ${passFile} rdp://${network}:${target.port} -t 4 -o ${outputFile}.rdp -f -v -I`;\n                break;\n        }\n        \n        console.log('CMD:', cmd);\n        \n        try {\n            await execPromise(cmd, { timeout: 120000, shell: '/bin/bash' });\n        } catch (e) {\n            console.log(`${target.service} scan completed (may have found credentials)`);\n        }\n        \n        // Lire les résultats\n        const resultFile = `${outputFile}.${target.service}`;\n        if (fs.existsSync(resultFile)) {\n            const content = fs.readFileSync(resultFile, 'utf-8');\n            const lines = content.split('\\n');\n            \n            for (const line of lines) {\n                // Extraire les credentials trouvés\n                // Format: [22][ssh] host: 192.168.1.1   login: root   password: toor\n                const match = line.match(/host:\\s*(\\S+)\\s+login:\\s*(\\S+)\\s+password:\\s*(.+)/i);\n                if (match) {\n                    hydraResults.push({\n                        tool: 'hydra',\n                        type: 'credential',\n                        service: target.service,\n                        port: target.port,\n                        host: match[1],\n                        username: match[2],\n                        password: match[3].trim(),\n                        severity: 'critical',\n                        description: `Weak credentials found for ${target.service} service`,\n                        remediation: `Change password for user '${match[2]}' immediately. Use strong, unique passwords.`\n                    });\n                }\n            }\n        }\n    }\n    \n    // Nettoyer les fichiers temporaires\n    try {\n        fs.unlinkSync(passFile);\n        fs.unlinkSync(userFile);\n    } catch(e) {}\n    \n    console.log(`✅ Hydra found ${hydraResults.length} weak credentials`);\n    \n    if (hydraResults.length === 0) {\n        hydraResults.push({\n            tool: 'hydra',\n            type: 'info',\n            id: 'NO_WEAK_CREDENTIALS',\n            severity: 'info',\n            description: 'No weak credentials found with common dictionaries',\n            url: network\n        });\n    }\n    \n} catch (error) {\n    console.error('❌ Hydra error:', error.message);\n    hydraResults.push({\n        tool: 'hydra',\n        type: 'error',\n        id: 'HYDRA_ERROR',\n        severity: 'info',\n        description: `Hydra scan error: ${error.message}`,\n        url: network\n    });\n}\n\nreturn [{ json: { hydraResults } }];"
