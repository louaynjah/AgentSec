    {
      "parameters": {
        "jsCode": "// Nœud \"Save Final Results\" - Version corrigée\nconst results = $input.first().json;\nconst scanData = $('1. Préparer les Paramètres').first().json;\nconst scanId = scanData.scanId;\nconst timestamp = scanData.timestamp;\n\n// Récupérer tous les résultats des scans\nconst mergerData = $('Merge Code').first().json;\nconst aiAnalysis = $('Groq AI Analysis').first().json.aiAnalysis;\nconst cveData = $('4. Enrichissement CVE').first().json;\nconst services = $('3. Parser les Services').first().json.services;\n\nconst fs = require('fs');\nconst tempDir = '/tmp/vulnscan';\nconst resultsDir = `${tempDir}/results`;\n\n// Créer le dossier des résultats\nif (!fs.existsSync(resultsDir)) {\n    fs.mkdirSync(resultsDir, { recursive: true });\n}\n\n// Sauvegarder TOUS les résultats complets\nconst fullResults = {\n    scanId: scanId,\n    timestamp: timestamp,\n    target: scanData.network,\n    status: 'completed',\n    completedAt: new Date().toISOString(),\n    pdf: {\n        path: results.pdfPath,\n        filename: results.filename,\n        size: results.fileSize\n    },\n    // Ajouter toutes les données des scans\n    scans: {\n        nmap: $('2. Exécuter Nmap (Ubuntu)').first().json,\n        nikto: mergerData.niktoResults || [],\n        ssl: mergerData.sslResults || [],\n        whatweb: mergerData.whatwebResults || [],\n        gobuster: mergerData.gobusterResults || [],\n        wpscan: mergerData.wpscanResults || [],\n        hydra: mergerData.hydraResults || []\n    },\n    services: services || [],\n    cves: cveData.enriched || [],\n    aiAnalysis: aiAnalysis || {},\n    // Garder le PDF info\n    pdfInfo: {\n        success: results.success,\n        pdfPath: results.pdfPath,\n        fileSize: results.fileSize,\n        filename: results.filename,\n        message: results.message\n    }\n};\n\nconst resultsFile = `${resultsDir}/${scanId}.json`;\nfs.writeFileSync(resultsFile, JSON.stringify(fullResults, null, 2));\n\nconsole.log(`✅ Results saved to: ${resultsFile}`);\nconsole.log(`   Target: ${scanData.network}`);\nconsole.log(`   AI Analysis: ${aiAnalysis ? 'present' : 'missing'}`);\nconsole.log(`   Findings: ${aiAnalysis?.stats?.total_findings || 0}`);\n\n// Supprimer le fichier de demande\nconst requestFile = `${tempDir}/request_${scanId}.json`;\nif (fs.existsSync(requestFile)) {\n    fs.unlinkSync(requestFile);\n}\n\nreturn [{\n    json: {\n        ...results,\n        scanId: scanId,\n        savedResults: resultsFile\n    }\n}];"
