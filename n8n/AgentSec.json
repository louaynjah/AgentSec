    {
      "parameters": {
        "jsCode": "const { execSync } = require('child_process');\nconst network = $('Extraire Ports Ouverts').first().json.network;\n\nconsole.log('WhatWeb target:', network);\n\ntry {\n    // WhatWeb installé dans /opt/WhatWeb\n    const cmd = `whatweb --log-json=- -a 3 http://${network}`;\n    const output = execSync(cmd, { encoding: 'utf-8', timeout: 45000 });\n    \n    let whatwebResults = [];\n    for (const line of output.trim().split('\\n').filter(l => l.trim())) {\n        try {\n            const data = JSON.parse(line);\n            const target = data.target || network;\n            const plugins = data.plugins || {};\n            \n            for (const [pluginName, pluginData] of Object.entries(plugins)) {\n                whatwebResults.push({\n                    tool: 'whatweb',\n                    type: 'technology',\n                    target,\n                    technology: pluginName,\n                    version: (pluginData.version || []).join(', ') || 'detected',\n                    string: (pluginData.string || []).join(', ')\n                });\n            }\n        } catch(e) {}\n    }\n    \n    console.log(`WhatWeb detected ${whatwebResults.length} technologies`);\n    return [{ json: { whatwebResults } }];\n    \n} catch (error) {\n    console.error('WhatWeb error:', error.message);\n    return [{ json: { whatwebResults: [], error: error.message } }];\n}"
      },
